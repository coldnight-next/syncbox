{
  "name": "syncbox",
  "version": "0.2.1",
  "description": "File sync desktop application",
  "author": "Syncbox",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "electron-vite dev --renderer-only",
    "build": "tsc --build && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc --build",
    "typecheck:watch": "tsc --build --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "package:win": "npm run package -- --win",
    "package:win:unsigned": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:win:signed": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:mac": "npm run package -- --mac",
    "package:linux": "npm run package -- --linux",
    "release": "npm run package && electron-builder --publish always",
    "clean": "rimraf dist out coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/backend": "^2.32.2",
    "@clerk/clerk-react": "^5.61.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "bonjour-service": "^1.3.0",
    "chokidar": "^4.0.0",
    "electron-log": "^5.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.0.0",
    "p-queue": "^8.0.0",
    "ws": "^8.19.0",
    "xxhash-wasm": "^1.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.45.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html,md}": [
      "prettier --write"
    ]
  }
}
